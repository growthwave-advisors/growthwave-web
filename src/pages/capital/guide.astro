---
/**
 * GrowthWave Capital — Credit Sculpt Series Landing Page
 * =======================================================
 * Replaces: generic lead magnet guide page (Feb 2026)
 *
 * Purpose: Branded 3-volume Credit Sculpt Series page.
 *   Vol. 1 — RE Investor Credit Blueprint (free download)
 *   Vol. 2 — The FCFM Framework (included in series)
 *   Vol. 3 — Zero Percent Playbook (included in series)
 *
 * Structure: Hero → Volume Cards → Authority Bar → Download Form → Footer CTA
 * Phase 1 (this file): Hero + Volume Cards
 * Phase 2: Authority Bar + Download Form + Footer CTA Strip
 *
 * GHL Integration (Phase 2):
 * - POST to /.netlify/functions/ghl-submit with formType: "guide"
 * - Tags: engagement:guide-downloaded, series:vol1-downloaded
 * - No pipelineStage (not supported by ghl-submit function)
 *
 * Design System:
 * - Fixed Island pattern (w-full background, max-w-7xl inner content)
 * - Typography stops at lg breakpoint (no xl: or 2xl: font sizes)
 * - Midnight Navy #022140 hero bg, Capital Purple #7C3AED CTAs
 * - Credit Sculpt Green #10B981 for Vol. 1 / free badge
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import GuideDownloadForm from '@components/capital/GuideDownloadForm';

const title = "Credit Sculpt Series — Free RE Investor Funding Guides | GrowthWave Capital";
const description = "Download the Credit Sculpt Series free — 3 volumes covering the investor credit profile, the FCFM framework, and the Zero Percent Playbook for real estate investors.";
---

<BaseLayout brand="capital" title={title} description={description}>
  <Header brand="capital" activePage="" />

  <main>

    <!-- ============================================================
         SECTION 1: HERO
         - Outer: w-full bg #022140 (Midnight Navy)
         - Inner: max-w-7xl, centered text layout
         ============================================================ -->
    <section class="w-full" style="background-color: #022140;">
      <div class="max-w-7xl mx-auto py-20 lg:py-28 px-4 lg:px-8 text-center">

        <!-- Badge pill -->
        <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-widest mb-6"
             style="background-color: rgba(124,58,237,0.20); color: #7C3AED; border: 1px solid rgba(124,58,237,0.30);">
          Credit Sculpt Series &mdash; 3-Volume Investor Library
        </div>

        <!-- H1 -->
        <h1 class="text-3xl lg:text-4xl font-bold text-white mt-6 leading-tight max-w-3xl mx-auto">
          The Funding Playbook Real Estate Investors Never Get Handed
        </h1>

        <!-- Subhead -->
        <p class="text-base lg:text-lg text-gray-300 mt-4 max-w-2xl mx-auto">
          A 3-volume guide series covering the credit profile, the strategy,
          and the playbook that moves investors from blocked to funded.
        </p>

        <!-- Book Visuals — placeholder spines (replace with actual cover images: public/images/capital/vol[N]-cover.png) -->
        <!-- Replace with actual cover images: public/images/capital/vol1-cover.png, vol2-cover.png, vol3-cover.png -->
        <div class="flex justify-center gap-6 mt-10 flex-wrap">
          <!-- Vol. 1 spine -->
          <div class="w-32 h-48 rounded flex flex-col items-center justify-center gap-2"
               style="background-color: #1a3a5c; border: 1px solid rgba(38,80,119,0.50);">
            <span class="text-xs font-bold uppercase tracking-wider" style="color: #10B981;">Vol. 1</span>
            <span class="text-white/30 text-xs text-center px-2 leading-snug">Credit Blueprint</span>
          </div>
          <!-- Vol. 2 spine -->
          <div class="w-32 h-48 rounded flex flex-col items-center justify-center gap-2"
               style="background-color: #1a3a5c; border: 1px solid rgba(38,80,119,0.50);">
            <span class="text-xs font-bold uppercase tracking-wider" style="color: #7C3AED;">Vol. 2</span>
            <span class="text-white/30 text-xs text-center px-2 leading-snug">FCFM Framework</span>
          </div>
          <!-- Vol. 3 spine -->
          <div class="w-32 h-48 rounded flex flex-col items-center justify-center gap-2"
               style="background-color: #1a3a5c; border: 1px solid rgba(38,80,119,0.50);">
            <span class="text-xs font-bold uppercase tracking-wider" style="color: #7C3AED;">Vol. 3</span>
            <span class="text-white/30 text-xs text-center px-2 leading-snug">Zero Percent Playbook</span>
          </div>
        </div>

        <!-- Primary CTA -->
        <a href="#guide-form"
           class="inline-block mt-10 px-8 py-4 rounded-lg font-semibold text-white transition-colors"
           style="background-color: #7C3AED;"
           onmouseover="this.style.backgroundColor='#6d28d9'"
           onmouseout="this.style.backgroundColor='#7C3AED'">
          Download Vol. 1 Free &rarr;
        </a>

      </div>
    </section>

    <!-- ============================================================
         SECTION 2: VOLUME CARDS
         - Outer: w-full bg gray-50
         - Inner: max-w-7xl, 3-column card grid
         ============================================================ -->
    <section class="w-full bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto py-16 lg:py-20 px-4 lg:px-8">

        <!-- Section header -->
        <h2 class="text-2xl lg:text-3xl font-bold text-[#022140] text-center mb-3">
          What&rsquo;s Inside the Series
        </h2>
        <p class="text-base text-gray-500 text-center mb-12">
          Three volumes. Each one builds on the last.
        </p>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">

          <!-- Card 1 — Vol. 1 (green) -->
          <div class="bg-white rounded-xl shadow-sm overflow-hidden flex flex-col">
            <!-- Green accent bar -->
            <div class="h-1" style="background-color: #10B981;"></div>
            <div class="p-6 flex flex-col flex-1">
              <!-- Badge + volume label -->
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-wider px-2 py-1 rounded"
                      style="background-color: rgba(16,185,129,0.10); color: #10B981;">
                  FREE DOWNLOAD
                </span>
                <span class="text-xs text-gray-400 font-medium">Vol. 1</span>
              </div>
              <!-- Title -->
              <h3 class="text-lg font-bold text-[#022140] mb-3">
                RE Investor Credit Blueprint
              </h3>
              <!-- Body -->
              <p class="text-sm text-gray-600 leading-relaxed flex-1">
                What lenders actually see when a real estate investor applies &mdash;
                and the profile that consistently gets the best terms.
              </p>
              <!-- CTA -->
              <a href="#guide-form"
                 class="mt-6 text-sm font-semibold hover:underline"
                 style="color: #10B981;">
                Download Free &rarr;
              </a>
            </div>
          </div>

          <!-- Card 2 — Vol. 2 (purple) -->
          <div class="bg-white rounded-xl shadow-sm overflow-hidden flex flex-col">
            <!-- Purple accent bar -->
            <div class="h-1 bg-[#7C3AED]"></div>
            <div class="p-6 flex flex-col flex-1">
              <!-- Badge + volume label -->
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-wider px-2 py-1 rounded bg-[#7C3AED]/10 text-[#7C3AED]">
                  INCLUDED IN SERIES
                </span>
                <span class="text-xs text-gray-400 font-medium">Vol. 2</span>
              </div>
              <!-- Title -->
              <h3 class="text-lg font-bold text-[#022140] mb-3">
                The FCFM Framework
              </h3>
              <!-- Body -->
              <p class="text-sm text-gray-600 leading-relaxed flex-1">
                Fix&middot;Consolidate&middot;Fund&middot;Move: the 4-step sequence from credit
                cleanup to $50K&ndash;$250K funded. Order matters more than most
                investors realize.
              </p>
              <!-- CTA -->
              <a href="#guide-form"
                 class="mt-6 text-sm font-semibold text-[#7C3AED] hover:underline">
                Start with Vol. 1 to unlock &rarr;
              </a>
            </div>
          </div>

          <!-- Card 3 — Vol. 3 (purple) -->
          <div class="bg-white rounded-xl shadow-sm overflow-hidden flex flex-col">
            <!-- Purple accent bar -->
            <div class="h-1 bg-[#7C3AED]"></div>
            <div class="p-6 flex flex-col flex-1">
              <!-- Badge + volume label -->
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-wider px-2 py-1 rounded bg-[#7C3AED]/10 text-[#7C3AED]">
                  INCLUDED IN SERIES
                </span>
                <span class="text-xs text-gray-400 font-medium">Vol. 3</span>
              </div>
              <!-- Title -->
              <h3 class="text-lg font-bold text-[#022140] mb-3">
                Zero Percent Playbook
              </h3>
              <!-- Body -->
              <p class="text-sm text-gray-600 leading-relaxed flex-1">
                How to move $50K&ndash;$250K at 0% APR &mdash; the window, the sequencing,
                the card targets, and how investors use it to fund deals.
              </p>
              <!-- CTA -->
              <a href="#guide-form"
                 class="mt-6 text-sm font-semibold text-[#7C3AED] hover:underline">
                Start with Vol. 1 to unlock &rarr;
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 3: AUTHORITY BAR
         - Outer: w-full bg #022140 (Midnight Navy)
         - Inner: max-w-7xl, single centered stats row
         ============================================================ -->
    <section class="w-full" style="background-color: #022140;">
      <div class="max-w-7xl mx-auto py-8 px-4 lg:px-8">
        <div class="flex justify-center items-center gap-6 lg:gap-12 flex-wrap">

          <div class="flex items-center gap-3">
            <span class="font-bold text-2xl lg:text-3xl" style="color: #7C3AED;">$80M+</span>
            <span class="text-gray-300 text-base">funded for clients</span>
          </div>

          <span class="text-gray-600 text-xl hidden lg:inline">&middot;</span>

          <div class="flex items-center gap-3">
            <span class="font-bold text-2xl lg:text-3xl" style="color: #7C3AED;">7,000+</span>
            <span class="text-gray-300 text-base">investors served</span>
          </div>

          <span class="text-gray-600 text-xl hidden lg:inline">&middot;</span>

          <div class="flex items-center gap-3">
            <span class="font-bold text-2xl lg:text-3xl" style="color: #7C3AED;">5,000+</span>
            <span class="text-gray-300 text-base">funding options</span>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4: DOWNLOAD FORM
         - Outer: w-full bg gray-50, id="guide-form" anchor
         - Inner: max-w-2xl, centered card layout
         ============================================================ -->
    <section id="guide-form" class="w-full bg-[#f9fafb]">
      <div class="max-w-2xl mx-auto py-16 lg:py-20 px-4 lg:px-8 text-center">

        <h2 class="text-2xl lg:text-3xl font-bold text-[#022140]">
          Get Vol. 1 Free &mdash; Instant Download
        </h2>
        <p class="text-base text-gray-500 mt-3 mb-8">
          Enter your name and email. Vol. 1 downloads immediately.<br />
          The series continues from there.
        </p>

        <div class="bg-white rounded-xl shadow-sm p-6 lg:p-8 text-left">
          <GuideDownloadForm client:load />
        </div>

      </div>
    </section>

    <!-- ============================================================
         SECTION 5: FOOTER CTA STRIP
         - Outer: w-full bg #7C3AED (Capital Purple)
         - Inner: max-w-7xl, centered text + white button
         ============================================================ -->
    <section class="w-full bg-[#7C3AED]">
      <div class="max-w-7xl mx-auto py-12 px-4 lg:px-8 text-center">

        <p class="text-lg lg:text-xl font-semibold text-white">
          Ready to go beyond the guide? Get pre-qualified in 3 minutes.
        </p>

        <a href="/contact?type=prequalify"
           class="inline-block mt-6 px-8 py-3 rounded-lg font-semibold text-sm transition-colors"
           style="background-color: #ffffff; color: #7C3AED;"
           onmouseover="this.style.backgroundColor='#f9fafb'"
           onmouseout="this.style.backgroundColor='#ffffff'">
          Start Pre-Qualification &rarr;
        </a>

      </div>
    </section>

  </main>

  <Footer brand="capital" />
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
