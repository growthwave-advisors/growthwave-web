---
/**
 * GrowthWave Properties - Homepage
 * =================================
 * Updated: January 2026
 * 
 * Design System Compliance:
 * - Two-layer "Fixed Island" pattern on all sections
 * - Typography stops at lg breakpoint (no xl: or 2xl:)
 * - Responsive padding: px-4 lg:px-8
 * - Body content: max-w-7xl (1280px)
 * 
 * Copy Updates Applied:
 * - "Midwest" → "Midwest & South" / "high-growth regional markets"
 * - Regional focus expanded to include Southern markets
 * 
 * @see Website_Design_System_STRATEGY.md
 * @see Website_Copy_Updates_January_2026.md
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Button from '@components/Button.astro';

// Brand Colors
const colors = {
  coral: '#FF6B4A',
  coralLight: '#ff8a6b',
  coralBg: 'rgba(255,107,74,0.2)',
  ocean: '#265077',
  midnight: '#022140',
  gray50: '#f9fafb',
  gray100: '#f3f4f6',
  gray300: '#d1d5db',
  gray400: '#9ca3af',
  gray500: '#6b7280',
  gray600: '#4b5563',
  gray700: '#374151',
  gray800: '#1f2937',
};

// UPDATED: Target Markets now includes South
const investmentCriteria = [
  { label: 'Property Size', value: '5-20 Units' },
  { label: 'Asset Class', value: 'B/C Class' },
  { label: 'Strategy', value: 'Value-Add' },
  { label: 'Hold Period', value: '2-5 Years' },
  { label: 'Target Markets', value: 'Midwest & South' },
];

// UPDATED: Regional Markets value prop
const valueProps = [
  { 
    title: 'Technology-Enabled', 
    desc: 'Enterprise-grade systems for analysis, reporting, and investor communications.' 
  },
  { 
    title: 'Conservative Underwriting', 
    desc: 'Every deal stress-tested with 7% vacancy and $450/unit reserves.' 
  },
  { 
    title: 'Regional Markets', 
    desc: 'High-growth markets across the Midwest and South with strong fundamentals.' 
  },
  { 
    title: 'Value-Add Strategy', 
    desc: 'Force appreciation through strategic renovations and operational improvements.' 
  },
  { 
    title: 'Transparent Reporting', 
    desc: 'Monthly updates with full financial transparency.' 
  },
  { 
    title: '1031 Exchange Planning', 
    desc: 'Strategic exits to compound wealth tax-efficiently.' 
  },
];

const challenges = [
  { 
    title: 'Lack of Deal Flow', 
    desc: "Finding off-market opportunities requires local relationships you haven't built." 
  },
  { 
    title: 'Operational Complexity', 
    desc: 'Managing tenants, maintenance, and renovations is a full-time job.' 
  },
  { 
    title: 'Analysis Paralysis', 
    desc: "Without proper underwriting, you can't separate good deals from bad ones." 
  },
];

const solutions = [
  'Professional deal analysis',
  'Hands-off investment',
  'Monthly reporting',
  'Strategic exits via 1031',
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is value-add multifamily investing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Value-add multifamily investing involves acquiring apartment properties that are underperforming, then increasing their value through strategic renovations, operational improvements, and revenue optimization. GrowthWave Properties focuses on 5-20 unit B/C class workforce housing across the Midwest and South with 2-5 year hold periods."
      }
    },
    {
      "@type": "Question",
      "name": "How does a joint venture real estate partnership work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In a JV partnership with GrowthWave Properties, you provide the capital while we handle everything: deal sourcing, underwriting, acquisition, renovation, and management. You receive monthly reporting with full financial transparency, and strategic exits are planned via 1031 exchanges to compound wealth tax-efficiently."
      }
    }
  ]
};
---

<BaseLayout
  brand="properties"
  title="GrowthWave Properties | Multifamily Investment Partnerships"
  description="Partner with experienced operators on value-add multifamily properties across the Midwest and South. Professional management, transparent reporting, proven results."
  extraJsonLd={[faqSchema]}
>
  <Header brand="properties" activePage="Home" />

  <main>
    <!-- ============================================
         HERO SECTION
         - Gradient background (full-width)
         - Two-column layout
         - Decorative wave at bottom
         ============================================ -->
    <section 
      class="w-full relative overflow-hidden"
      style={`background: linear-gradient(135deg, ${colors.midnight} 0%, ${colors.ocean} 100%);`}
    >
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-16 lg:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          
          <!-- Content Column -->
          <div>
            <!-- Badge -->
            <div 
              class="inline-block px-3 py-1 rounded-full text-xs lg:text-sm font-medium mb-4"
              style={`background-color: ${colors.coralBg}; color: ${colors.coral};`}
            >
              Value-Add Multifamily Investment
            </div>
            
            <!-- Headline: stops at lg -->
            <h1 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-6">
              Build Wealth Through<br/>
              <span style={`color: ${colors.coral};`}>Strategic Real Estate</span>
            </h1>
            
            <!-- Subheadline: stops at lg -->
            <p class="text-base lg:text-xl text-gray-300 mb-8 leading-relaxed">
              Partner with experienced operators on cash-flowing multifamily properties 
              across high-growth regional markets. You bring the capital, we bring the deals and expertise.
            </p>
            
            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-4">
              <Button brand="properties" href="/contact" size="lg">
                Join Our Investor List
              </Button>
              <Button brand="properties" variant="outline" href="/approach" size="lg" showArrow>
                Learn Our Approach
              </Button>
            </div>
          </div>
          
          <!-- Deal Pipeline Card — Option A -->
          <div class="relative hidden lg:block">

            <!-- Ambient glow behind card -->
            <div 
              class="absolute -inset-6 rounded-3xl opacity-25 pointer-events-none"
              style="background: radial-gradient(ellipse at center, rgba(255,107,74,0.6) 0%, transparent 70%);"
            ></div>

            <!-- Main portal card -->
            <div 
              class="relative rounded-2xl overflow-hidden shadow-2xl"
              style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(12px);"
            >

              <!-- Card header -->
              <div 
                class="px-5 py-3.5 flex items-center justify-between"
                style="background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08);"
              >
                <div class="flex items-center gap-2.5">
                  <div 
                    class="w-7 h-7 rounded-lg flex items-center justify-center"
                    style="background: rgba(255,107,74,0.2);"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                      <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                  </div>
                  <span class="text-sm font-semibold text-white">Deal Review Portal</span>
                </div>
                <div 
                  class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold"
                  style="background: rgba(16,185,129,0.15); color: #10B981;"
                >
                  <span class="w-1.5 h-1.5 rounded-full" style="background: #10B981;"></span>
                  Live
                </div>
              </div>

              <!-- Property info -->
              <div class="p-5">

                <!-- Property header -->
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <div class="text-xs uppercase tracking-wider mb-1" style="color: #9ca3af;">Current Opportunity</div>
                    <div class="text-base font-bold text-white leading-tight">
                      8-Unit Value-Add<br/>
                      <span style="color: #FF6B4A;">Indianapolis, IN</span>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs mb-1" style="color: #9ca3af;">Status</div>
                    <div 
                      class="px-2.5 py-1 rounded-full text-xs font-semibold"
                      style="background: rgba(16,185,129,0.15); color: #10B981;"
                    >
                      Under LOI
                    </div>
                  </div>
                </div>

                <!-- Metrics grid -->
                <div class="grid grid-cols-3 gap-3 mb-4">
                  {[
                    { value: '8', label: 'Units' },
                    { value: 'B', label: 'Class' },
                    { value: '3yr', label: 'Hold' },
                  ].map(m => (
                    <div 
                      class="rounded-xl p-3 text-center"
                      style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);"
                    >
                      <div class="text-lg font-bold" style={m.label === 'Hold' ? 'color: #ffffff;' : 'color: #FF6B4A;'}>{m.value}</div>
                      <div class="text-xs" style="color: #9ca3af;">{m.label}</div>
                    </div>
                  ))}
                </div>

                <!-- Equity projection bar -->
                <div class="mb-4">
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-xs" style="color: #9ca3af;">Projected Equity Growth</span>
                    <span class="text-xs font-semibold" style="color: #FF6B4A;">Year 1 → Year 3</span>
                  </div>
                  <div class="h-2 rounded-full overflow-hidden" style="background: rgba(255,255,255,0.08);">
                    <div 
                      class="h-full rounded-full"
                      style="width: 72%; background: linear-gradient(90deg, #FF6B4A, #ff8a6b);"
                    ></div>
                  </div>
                  <div class="flex justify-between text-xs mt-1" style="color: #6b7280;">
                    <span>Acquisition</span>
                    <span style="color: #FF6B4A;">72% equity build</span>
                  </div>
                </div>

                <!-- Partner status row -->
                <div 
                  class="flex items-center justify-between pt-3"
                  style="border-top: 1px solid rgba(255,255,255,0.06);"
                >
                  <div class="flex items-center gap-2">
                    <div 
                      class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white"
                      style="background: linear-gradient(135deg, #265077, #022140);"
                    >
                      FA
                    </div>
                    <div>
                      <div class="text-xs font-semibold text-white">Franklin A.</div>
                      <div class="text-xs" style="color: #6b7280;">JV Partner</div>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs" style="color: #9ca3af;">Docs Received</div>
                    <div class="flex gap-1 mt-1 justify-end">
                      {[1,2,3].map(() => (
                        <div class="w-2 h-2 rounded-full" style="background: #10B981;"></div>
                      ))}
                      <div class="w-2 h-2 rounded-full" style="background: rgba(255,255,255,0.15);"></div>
                    </div>
                  </div>
                </div>

              </div>

              <!-- Distribution notice -->
              <div class="px-5 pb-4">
                <div 
                  class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl"
                  style="background: rgba(255,107,74,0.08); border: 1px solid rgba(255,107,74,0.15);"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                  </svg>
                  <span class="text-xs text-white">Monthly distributions begin Q3 2026</span>
                  <span class="ml-auto text-xs font-semibold" style="color: #FF6B4A;">On Track</span>
                </div>
              </div>

            </div>
          </div>
          
        </div>
      </div>
      
      <!-- Decorative wave -->
      <div 
        class="absolute bottom-0 left-0 right-0 h-12 lg:h-16 bg-white"
        style="clip-path: polygon(0 100%, 100% 100%, 100% 0, 0 100%);"
      ></div>
    </section>

    <!-- ============================================
         CHALLENGE / SOLUTION SECTION
         ============================================ -->
    <section class="w-full" style={`background-color: ${colors.gray50};`}>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12 lg:py-20">
        
        <!-- Section Header -->
        <div class="text-center mb-12 lg:mb-16">
          <h2 
            class="text-2xl lg:text-3xl font-bold mb-4"
            style={`color: ${colors.midnight};`}
          >
            The Real Estate Investor's Dilemma
          </h2>
          <p 
            class="text-base lg:text-lg max-w-2xl mx-auto"
            style={`color: ${colors.gray600};`}
          >
            You want to build wealth through real estate, but finding great deals 
            and managing properties requires expertise you don't have time to develop.
          </p>
        </div>
        
        <!-- Two Column Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          
          <!-- Challenges Column -->
          <div class="space-y-4 lg:space-y-6">
            {challenges.map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                  <span class="text-red-500">✕</span>
                </div>
                <div>
                  <h4 
                    class="text-base lg:text-lg font-semibold"
                    style={`color: ${colors.gray800};`}
                  >
                    {item.title}
                  </h4>
                  <p 
                    class="text-sm lg:text-base"
                    style={`color: ${colors.gray600};`}
                  >
                    {item.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>
          
          <!-- Solution Card -->
          <div 
            class="p-6 lg:p-8 rounded-2xl bg-white shadow-xl border-l-4"
            style={`border-color: ${colors.coral};`}
          >
            <h3 
              class="text-xl lg:text-2xl font-bold mb-4"
              style={`color: ${colors.ocean};`}
            >
              Our Solution
            </h3>
            <p 
              class="text-base lg:text-lg mb-6"
              style={`color: ${colors.gray600};`}
            >
              We handle everything: deal sourcing, underwriting, acquisition, renovation, and management. 
              You participate as a joint venture partner with full transparency.
            </p>
            <ul class="space-y-3">
              {solutions.map((item) => (
                <li class="flex items-center gap-3">
                  <span style={`color: ${colors.coral};`}>✓</span>
                  <span 
                    class="text-sm lg:text-base"
                    style={`color: ${colors.gray700};`}
                  >
                    {item}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          
        </div>
      </div>
    </section>

    <!-- ============================================
         VALUE PROPS SECTION
         ============================================ -->
    <section class="w-full bg-white">
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12 lg:py-20">
        
        <!-- Section Header -->
        <h2 
          class="text-2xl lg:text-3xl font-bold text-center mb-4"
          style={`color: ${colors.midnight};`}
        >
          Why Partner With GrowthWave Properties
        </h2>
        <p 
          class="text-center text-base lg:text-lg mb-10 lg:mb-12 max-w-2xl mx-auto"
          style={`color: ${colors.gray600};`}
        >
          We combine deep institutional expertise with technology-enabled operations.
        </p>
        
        <!-- Value Props Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {valueProps.map((item, i) => (
            <div 
              class="p-5 lg:p-6 rounded-xl hover:shadow-lg transition-shadow border"
              style={`background-color: ${colors.gray50}; border-color: ${colors.gray100};`}
            >
              <div 
                class="w-10 h-10 lg:w-12 lg:h-12 rounded-lg mb-4 flex items-center justify-center"
                style={`background-color: ${colors.coralBg};`}
              >
                <span 
                  class="text-lg lg:text-xl font-bold"
                  style={`color: ${colors.coral};`}
                >
                  {i + 1}
                </span>
              </div>
              <h4 
                class="text-base lg:text-lg font-semibold mb-2"
                style={`color: ${colors.ocean};`}
              >
                {item.title}
              </h4>
              <p 
                class="text-sm lg:text-base"
                style={`color: ${colors.gray600};`}
              >
                {item.desc}
              </p>
            </div>
          ))}
        </div>
        
      </div>
    </section>

    <!-- ============================================
         INVESTMENT CRITERIA SECTION
         - Dark background (full-width)
         ============================================ -->
    <section class="w-full" style={`background-color: ${colors.midnight};`}>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          
          <!-- Content Column -->
          <div>
            <h2 class="text-2xl lg:text-3xl font-bold text-white mb-6">
              Our Investment Criteria
            </h2>
            <div class="space-y-4">
              {investmentCriteria.map((item) => (
                <div 
                  class="flex justify-between items-center py-3 border-b"
                  style={`border-color: ${colors.gray700};`}
                >
                  <span 
                    class="text-sm lg:text-base"
                    style={`color: ${colors.gray400};`}
                  >
                    {item.label}
                  </span>
                  <span 
                    class="text-sm lg:text-base font-semibold"
                    style={`color: ${colors.coral};`}
                  >
                    {item.value}
                  </span>
                </div>
              ))}
            </div>
            <div class="mt-8">
              <Button brand="properties" href="/approach" showArrow>
                View Full Approach
              </Button>
            </div>
          </div>
          
          <!-- Market Coverage Card -->
          <div class="hidden lg:block">
            <div 
              class="rounded-2xl p-6 shadow-xl"
              style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);"
            >
              <div class="text-xs uppercase tracking-wider mb-4" style="color: #9ca3af;">Active Markets</div>
              <div class="space-y-3">
                {[
                  { city: 'Indianapolis, IN', region: 'Midwest — Primary Market', status: 'Active', statusColor: '#10B981', statusBg: 'rgba(16,185,129,0.15)' },
                  { city: 'Kansas City, MO',  region: 'Midwest — Primary Market', status: 'Active', statusColor: '#10B981', statusBg: 'rgba(16,185,129,0.15)' },
                  { city: 'Jackson, MS',      region: 'South — Emerging Market',  status: 'Evaluating', statusColor: '#51A7F8', statusBg: 'rgba(81,167,248,0.15)' },
                  { city: 'Florida',          region: 'South — Emerging Market',  status: 'Evaluating', statusColor: '#51A7F8', statusBg: 'rgba(81,167,248,0.15)' },
                ].map((m, i) => (
                  <div 
                    class="flex items-center gap-3 p-3 rounded-xl"
                    style={i === 0
                      ? 'background: rgba(255,107,74,0.08); border: 1px solid rgba(255,107,74,0.15);'
                      : 'background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);'
                    }
                  >
                    <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: #FF6B4A;"></div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-semibold text-white">{m.city}</div>
                      <div class="text-xs" style="color: #6b7280;">{m.region}</div>
                    </div>
                    <div 
                      class="px-2 py-0.5 rounded-full text-xs font-semibold flex-shrink-0"
                      style={`background: ${m.statusBg}; color: ${m.statusColor};`}
                    >
                      {m.status}
                    </div>
                  </div>
                ))}
              </div>
              <div 
                class="mt-4 pt-3 flex justify-between items-center"
                style="border-top: 1px solid rgba(255,255,255,0.06);"
              >
                <span class="text-xs" style="color: #6b7280;">Buy Box: 5-20 units | B/C Class</span>
                <a 
                  href="/approach" 
                  class="text-xs font-semibold transition-opacity hover:opacity-80"
                  style="color: #FF6B4A;"
                >
                  View Criteria →
                </a>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- ============================================
         CTA SECTION
         - Coral gradient (full-width)
         ============================================ -->
    <section 
      class="w-full"
      style={`background: linear-gradient(135deg, ${colors.coral} 0%, ${colors.coralLight} 100%);`}
    >
      <div class="max-w-4xl mx-auto px-4 lg:px-8 py-16 lg:py-24 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
          Ready to Build Your Real Estate Portfolio?
        </h2>
        <p class="text-base lg:text-xl text-white/80 mb-8 max-w-2xl mx-auto">
          Join our investor list to receive updates on current and upcoming 
          opportunities across high-growth regional markets.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/contact"
            class="px-6 lg:px-8 py-3 lg:py-4 rounded-lg font-semibold text-base lg:text-lg bg-white transition-opacity hover:opacity-90"
            style={`color: ${colors.coral};`}
          >
            Join Investor List
          </a>
          <a 
            href="/contact"
            class="px-6 lg:px-8 py-3 lg:py-4 rounded-lg font-semibold text-base lg:text-lg border-2 border-white text-white transition-colors hover:bg-white/10"
          >
            Schedule a Call
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer brand="properties" />
</BaseLayout>
