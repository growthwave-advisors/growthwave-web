---
/**
 * GrowthWave Properties - Resources / Lead Magnet Page
 * =====================================================
 * Created: March 2026
 *
 * Purpose: Properties lead magnet landing page for "The Retirement
 * Concentration Problem" guide (eBook in production). Captures investor
 * leads in exchange for early access. Leads enter Track 2 nurture
 * sequence on form submit.
 *
 * Modeled after: Capital's /capital/guide page structure
 *
 * GHL Integration:
 * - formType: "properties-guide"
 * - Direct POST to /.netlify/functions/ghl-submit
 * - Honeypot + Turnstile bot protection
 *
 * Design System Compliance:
 * - Fixed Island pattern (max-w-7xl content, full-width backgrounds)
 * - Typography stops at lg breakpoint (no xl: or 2xl:)
 * - Coral #FF6B4A accent
 * - Responsive padding: px-4 lg:px-8
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Footer from '@components/Footer.astro';

// Properties color constants
const colors = {
  coral: '#FF6B4A',
  coralBg: 'rgba(255,107,74,0.15)',
  coralBgLight: 'rgba(255,107,74,0.08)',
  ocean: '#265077',
  midnight: '#022140',
  gray500: '#595959',
  labelGray: '#718EA7',
  light: '#f0f9ff',
  gray50: '#f9fafb',
  gray200: '#e5e7eb',
  gray600: '#4b5563',
};

// What's inside the guide
const guideContents = [
  {
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'The Concentration Risk Hiding in Your Portfolio',
    desc: 'Most retirement accounts hold 30\u201335% of their value in just 7 companies. Understand what that means for your long-term wealth.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'The SDIRA Blueprint: How to Redirect Retirement Capital Into Real Estate',
    desc: 'Self-directed IRAs have been legal since 1974. Learn the step-by-step process to move funds into real assets.',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Your First Move: How to Get Started in 60 Days',
    desc: 'A practical action plan for getting your retirement capital working in real estate \u2014 without triggering a taxable event.',
  },
];

// Turnstile site key — public-facing key, read from env at build time.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  brand="properties"
  title="The Retirement Concentration Problem | GrowthWave Properties"
  description="Most retirement accounts hold 30-35% in just 7 companies. Get the free guide on how self-directed investors are protecting their wealth with real estate."
>
  <!-- Minimal header — logo only, no nav -->
  <header class="w-full bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-4">
      <a href="/" class="inline-block">
        <img
          src="/images/logos/properties/growthwave-properties_horizontal_color.svg"
          alt="GrowthWave Properties"
          class="h-8 lg:h-10"
        />
      </a>
    </div>
  </header>

  <main>
    <!-- ============================================
         HERO SECTION — Two-column
         - Dark Navy background
         - Left: Text content
         - Right: Form card
         ============================================ -->
    <section
      class="w-full"
      style={`background: linear-gradient(135deg, ${colors.midnight} 0%, ${colors.ocean} 100%);`}
    >
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-14 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

          <!-- Left: Text Content -->
          <div class="lg:pr-4">
            <!-- Eyebrow -->
            <div
              class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs lg:text-sm font-semibold mb-5"
              style={`background-color: ${colors.coralBg}; color: ${colors.coral};`}
            >
              <!-- Book icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
              </svg>
              Free Investor Resource
            </div>

            <!-- H1 -->
            <h1 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-5">
              The Retirement
              <span style={`color: ${colors.coral};`}> Concentration Problem</span>
            </h1>

            <!-- Subtext -->
            <p class="text-base lg:text-lg text-gray-300 leading-relaxed mb-6">
              Most retirement accounts hold 30&ndash;35% of their value in just 7 companies &mdash;
              5 in the same industry. This guide exposes the concentration risk hiding in plain
              sight and shows you exactly what self-directed investors are doing instead.
            </p>

            <!-- Social proof -->
            <p class="text-sm text-gray-400 mb-6">
              Join 200+ investors on the early access list
            </p>

            <!-- Bullet points with coral checkmarks -->
            <div class="space-y-3 mb-6">
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-gray-300">
                  Understand why &ldquo;diversified&rdquo; index funds aren&rsquo;t as diversified as you think
                </span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-gray-300">
                  Learn how self-directed IRAs have been legal since 1974 &mdash; and why no one tells you
                </span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-gray-300">
                  Discover how to move retirement funds into real assets without triggering a taxable event
                </span>
              </div>
            </div>
          </div>

          <!-- Right: Form Card -->
          <div
            class="rounded-2xl p-6 lg:p-8 bg-white"
            style="box-shadow: 0 20px 40px rgba(0,0,0,0.2);"
          >
            <div class="text-center mb-6">
              <h2
                class="text-lg lg:text-xl font-bold mb-1"
                style={`color: ${colors.midnight};`}
              >
                Get Early Access &mdash; Free
              </h2>
            </div>

            <!-- Lead Magnet Form -->
            <form id="resource-form" class="space-y-3">
              <!-- Honeypot -->
              <input
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
                style="display:none; position:absolute; left:-9999px;"
              />
              <!-- Cloudflare Turnstile -->
              {turnstileSiteKey && (
                <div
                  class="cf-turnstile"
                  data-sitekey={turnstileSiteKey}
                  data-theme="light"
                  data-size="invisible"
                />
              )}

              <!-- First Name -->
              <div>
                <input
                  type="text"
                  name="first_name"
                  placeholder="First name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
                />
              </div>

              <!-- Last Name -->
              <div>
                <input
                  type="text"
                  name="last_name"
                  placeholder="Last name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
                />
              </div>

              <!-- Email -->
              <div>
                <input
                  type="email"
                  name="email"
                  placeholder="Email address"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
                />
              </div>

              <!-- Phone -->
              <div>
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone (optional)"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
                />
              </div>

              <!-- SMS Consent -->
              <label class="flex items-start gap-3 cursor-pointer mt-2">
                <input type="checkbox" name="smsConsent" class="mt-0.5 rounded flex-shrink-0" />
                <span class="text-xs leading-relaxed" style={`color: ${colors.labelGray};`}>
                  I agree to receive SMS messages from <strong style={`color: ${colors.midnight};`}>GrowthWave Properties</strong> including resource delivery and investment updates. Msg &amp; data rates may apply. Reply <strong style={`color: ${colors.midnight};`}>STOP</strong> to opt out. View our <a href="/privacy" class="underline" style={`color: ${colors.ocean};`}>Privacy Policy</a> and <a href="/terms" class="underline" style={`color: ${colors.ocean};`}>Terms of Service</a>.
                </span>
              </label>

              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full py-3.5 rounded-lg font-bold text-sm text-white transition-all hover:scale-[1.02] hover:shadow-lg mt-2"
                style={`background-color: ${colors.coral};`}
              >
                Send Me the Guide &rarr;
              </button>

              <!-- Below button -->
              <p class="text-center text-xs mt-2" style={`color: ${colors.labelGray};`}>
                Published Q2 2026 &mdash; you&rsquo;ll get first access the moment it&rsquo;s live.
              </p>
            </form>

            <!-- Success State -->
            <div id="resource-success" class="hidden text-center py-6">
              <div class="text-3xl mb-3">&#x2705;</div>
              <h3
                class="text-lg font-bold mb-2"
                style={`color: ${colors.midnight};`}
              >
                You&rsquo;re on the Early Access List!
              </h3>
              <p class="text-sm leading-relaxed" style={`color: ${colors.gray500};`}>
                We&rsquo;ll send the guide the moment it&rsquo;s published. Keep an eye on your inbox.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         WHAT'S INSIDE — Content Preview
         - White background
         - Three content cards with icons
         ============================================ -->
    <section class="w-full py-14 lg:py-20 px-4 lg:px-8 bg-white">
      <div class="max-w-7xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-10">
          <h2
            class="text-2xl lg:text-[32px] font-bold mb-3"
            style={`color: ${colors.midnight};`}
          >
            What&rsquo;s Inside the Guide
          </h2>
          <p class="text-base max-w-xl mx-auto" style={`color: ${colors.gray600};`}>
            A practical guide for investors who want their retirement capital working harder.
          </p>
        </div>

        <!-- Content Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
          {guideContents.map((item) => (
            <div
              class="flex flex-col items-start p-6 rounded-xl bg-white border"
              style={`border-color: ${colors.gray200}; box-shadow: 0 4px 16px rgba(0,0,0,0.04);`}
            >
              <!-- Icon -->
              <div
                class="flex-shrink-0 flex items-center justify-center rounded-xl mb-4"
                style={`width: 48px; height: 48px; background: linear-gradient(135deg, ${colors.coralBg} 0%, ${colors.coralBgLight} 100%); border: 1px solid rgba(255,107,74,0.25);`}
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF6B4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={item.icon}></path>
                </svg>
              </div>
              <h3
                class="text-base lg:text-lg font-bold mb-2"
                style={`color: ${colors.midnight};`}
              >
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed" style={`color: ${colors.gray600};`}>
                {item.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer brand="properties" />
</BaseLayout>

<!-- Form focus styles -->
<style>
  #resource-form input:focus,
  #resource-form select:focus {
    box-shadow: 0 0 0 2px rgba(255, 107, 74, 0.4);
    border-color: #FF6B4A;
  }
</style>

<!-- Form submission handler -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("resource-form");
    const successEl = document.getElementById("resource-success");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = "SUBMITTING...";
        submitBtn.disabled = true;
        submitBtn.style.opacity = "0.7";

        // ── Client-side guards ──────────────────────────────────────────
        const honeypot = formData.get("website") || "";
        const firstNameVal = (formData.get("first_name") || "").trim();
        const emailVal = (formData.get("email") || "").trim();
        const turnstileToken = formData.get("cf-turnstile-response") || "";

        if (honeypot.trim() !== "") {
          console.warn("Bot detected via honeypot — suppressing submission.");
          form.classList.add("hidden");
          successEl.classList.remove("hidden");
          return;
        }

        if (!firstNameVal || !emailVal) {
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          submitBtn.style.opacity = "1";
          alert("Please enter your first name and email address.");
          return;
        }
        // ────────────────────────────────────────────────────────────────

        try {
          const res = await fetch("/.netlify/functions/ghl-submit", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              formType: "properties-guide",
              website: honeypot,
              turnstileToken,
              firstName: firstNameVal,
              lastName: (formData.get("last_name") || "").trim(),
              email: emailVal,
              phone: formData.get("phone") || "",
            }),
          });

          const result = await res.json();

          if (res.ok && result.success) {
            form.classList.add("hidden");
            successEl.classList.remove("hidden");
          } else {
            console.error("GHL submit error:", result);
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
            submitBtn.style.opacity = "1";
            alert("Something went wrong. Please try again.");
          }
        } catch (err) {
          console.error("Form submission failed:", err);
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          submitBtn.style.opacity = "1";
          alert("Connection error. Please check your internet and try again.");
        }
      });
    }
  });
</script>
