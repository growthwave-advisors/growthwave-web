---
/**
 * BaseLayout Component
 * ====================
 * Master layout providing consistent HTML structure, SEO metadata,
 * favicons, Google Fonts, and JSON-LD structured data for all pages.
 * 
 * Analytics:
 * - GA4: Per-brand Measurement IDs, production-only, injected via gtag.js
 * - Microsoft Clarity: Single project (vosn1u2n4h), all brands, production-only
 * 
 * GA4 Properties (GrowthWave Advisors LLC account — 297586969):
 *   capital    → G-PNJTDE4V70
 *   properties → G-8L6Z00HEEQ
 *   advisors   → G-MDCTZQJZX4
 * 
 * @param brand - Brand identifier for theming and SEO
 * @param title - Optional page title override (defaults to brand SEO title)
 * @param description - Optional meta description override
 */
import type { BrandId } from '@brand-types/brand';
import { getBrand } from '@config/brands';
import '@styles/global.css';

type Props = {
  brand: BrandId;
  title?: string;
  description?: string;
};

const { brand, title, description } = Astro.props as Props;
const brandConfig = getBrand(brand);

const pageTitle = title ?? brandConfig.seo.title;
const pageDescription = description ?? brandConfig.seo.description;

// ── Analytics ──────────────────────────────────────────────────────────────
// Scripts only fire in production builds (not local dev, not preview branches).
// Add new brands here as they go live.
const isProd = import.meta.env.PROD;

const GA4_IDS: Record<string, string> = {
  capital:    'G-PNJTDE4V70',
  properties: 'G-8L6Z00HEEQ',
  advisors:   'G-MDCTZQJZX4',
};
const ga4Id = GA4_IDS[brand] ?? null;

const CLARITY_PROJECT_ID = 'vosn1u2n4h';
// ───────────────────────────────────────────────────────────────────────────

// JSON-LD structured data for organization
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brandConfig.name,
  url: `https://${brandConfig.seo.domain}`,
  logo: `https://${brandConfig.seo.domain}${brandConfig.logos.primary}`,
  description: brandConfig.tagline,
  contactPoint: {
    '@type': 'ContactPoint',
    email: brandConfig.contact.email,
    contactType: 'customer service',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Orlando',
    addressRegion: 'FL',
    addressCountry: 'US',
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://${brandConfig.seo.domain}${Astro.url.pathname}`} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`https://${brandConfig.seo.domain}${brandConfig.seo.ogImage}`} />
    <meta property="og:url" content={`https://${brandConfig.seo.domain}${Astro.url.pathname}`} />
    <meta property="og:site_name" content={brandConfig.name} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`https://${brandConfig.seo.domain}${brandConfig.seo.ogImage}`} />
    
    <!-- Favicons -->
    <link rel="icon" href={`/favicon/${brand}/favicon.ico`} sizes="32x32" />
    <link rel="icon" href={`/favicon/${brand}/favicon-16x16.png`} sizes="16x16" type="image/png" />
    <link rel="icon" href={`/favicon/${brand}/favicon-32x32.png`} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={`/favicon/${brand}/apple-touch-icon.png`} />
    <link rel="manifest" href={`/favicon/${brand}/site.webmanifest`} />
    
    <!-- Theme Color -->
    <meta name="theme-color" content={brandConfig.colors.dark} />
    
    <!-- Google Fonts - Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" 
      rel="stylesheet"
    />
    
    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- ── Google Analytics 4 ─────────────────────────────────────────────
         Production only. Per-brand Measurement ID resolved from GA4_IDS map.
         Fires on: growthwavecapital.com, growthwaveproperties.com,
                   growthwaveadvisors.com
         Does NOT fire: localhost, preview deployments (import.meta.env.PROD)
    ─────────────────────────────────────────────────────────────────────── -->
    {isProd && ga4Id && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
        />
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id, {
            // Anonymize IPs for GDPR compliance
            anonymize_ip: true,
            // Send page_view on load (default true — explicit for clarity)
            send_page_view: true,
          });
        </script>
      </>
    )}

    <!-- ── Microsoft Clarity ──────────────────────────────────────────────
         Production only. Single project covers all three GrowthWave brands.
         Filter by hostname inside Clarity dashboard for per-brand views.
         Project ID: vosn1u2n4h
    ─────────────────────────────────────────────────────────────────────── -->
    {isProd && (
      <script is:inline>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "vosn1u2n4h");
      </script>
    )}

  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <slot />
  </body>
</html>
